# ============================================================
# Tabi-Pay 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# .env.local は .gitignore で除外済みです
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...（Supabase > Settings > API）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...（Supabase > Settings > API > service_role）

# --- LINE LIFF ---
NEXT_PUBLIC_LIFF_ID=1234567890-xxxxxxxx（LINE Developers > LIFF）

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=...（LINE Developers > Messaging API > Channel access token）

# --- セキュリティ：許可するLINEグループID ---
# LINEグループチャットのgroupId（起動時にliff.getContext().groupIdで確認）
ALLOWED_LINE_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Vercel Cron 認証 ---
CRON_SECRET=（任意のランダム文字列。openssl rand -hex 32 などで生成）

# --- アプリURL（精算完了時のLINE通知でPDFリンクに使用） ---
# 例: https://your-app.vercel.app（末尾スラッシュなし）
# 未設定時はVERCEL_URLを自動利用（Vercelデプロイ時）
APP_URL=https://your-app.vercel.app

# --- ローカル開発用（LIFFはHTTPS必須のためVercel Preview URLを使う） ---
NEXT_PUBLIC_DEV_GROUP_ID=（開発時のフォールバックgroupId、本番では不要）
