# ============================================================
# 環境変数・シークレット（絶対にコミットしない）
# ============================================================
.env
.env.*
!.env.example

# LINE / LIFF 関連の秘密情報
channel_secret*
channel_access_token*
liff_id*

# Google / Firebase 認証情報
serviceAccountKey.json
firebase-adminsdk*.json
*.pem
*.key
*.p12
*.pfx
gcloud-credentials.json

# ============================================================
# 依存パッケージ
# ============================================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged

# ============================================================
# ビルド成果物
# ============================================================
dist/
build/
out/
.next/
.nuxt/

# ============================================================
# ログ・一時ファイル
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.bak
*.swp

# ============================================================
# ローカルDB・アップロードファイル
# ============================================================
*.sqlite
*.sqlite3
*.db
uploads/
storage/

# ============================================================
# OS 生成ファイル
# ============================================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS（他のメンバーが Mac を使う場合も想定）
.DS_Store
.AppleDouble
.LSOverride
._*

# ============================================================
# IDE・エディタ設定
# ============================================================
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ============================================================
# テスト・カバレッジ
# ============================================================
coverage/
.nyc_output/

# ============================================================
# Vercel / Cloudflare / その他デプロイ設定（ローカル固有）
# ============================================================
.vercel
.wrangler/
